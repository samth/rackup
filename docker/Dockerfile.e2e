FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      bash \
      ca-certificates \
      coreutils \
      curl \
      findutils \
      gzip \
      racket \
      tar \
      xz-utils && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /work

CMD ["bash"]
