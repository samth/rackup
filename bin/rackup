#!/bin/sh
set -eu

SELF_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
LIBEXEC_DIR="$SELF_DIR/../libexec"
CORE="$LIBEXEC_DIR/rackup-core.rkt"
BOOTSTRAP_SH="$LIBEXEC_DIR/rackup-bootstrap.sh"

if [ ! -r "$BOOTSTRAP_SH" ]; then
  echo "rackup: missing bootstrap helper: $BOOTSTRAP_SH" >&2
  exit 1
fi

. "$BOOTSTRAP_SH"

if [ "${1:-}" = "prompt" ]; then
  case "$#" in
    1)
      rackup_prompt_shell
      exit 0
      ;;
    2)
      case "${2:-}" in
        -h|--help)
          rackup_prompt_help_shell
          exit 0
          ;;
        --raw|--source|--short|--long)
          rackup_prompt_shell "$2"
          exit 0
          ;;
      esac
      ;;
  esac
fi

if [ "${1:-}" = "help" ] && [ "${2:-}" = "prompt" ] && [ "$#" -eq 2 ]; then
  rackup_prompt_help_shell
  exit 0
fi

RACKET_EXE="$(rackup_select_runtime_racket_or_fail)" || exit 1
RUNTIME_ADDON_DIR="$(rackup_runtime_addon_dir)"
rackup_mkdir_p "$RUNTIME_ADDON_DIR"
unset PLTHOME PLTCOLLECTS PLTADDONDIR
exec "$RACKET_EXE" -U -A "$RUNTIME_ADDON_DIR" "$CORE" "$@"
